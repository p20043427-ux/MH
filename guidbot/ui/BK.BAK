            "가동률": 84.0,
        },
        {
            "기준일": "3/6",
            "병동명": "1병동(내과)",
            "금일입원": 3,
            "금일퇴원": 4,
            "금일재원": 41,
            "가동률": 82.0,
        },
        {
            "기준일": "3/7",
            "병동명": "1병동(내과)",
            "금일입원": 4,
            "금일퇴원": 3,
            "금일재원": 42,
